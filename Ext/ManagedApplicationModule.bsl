
&Перед("ПередНачаломРаботыСистемы")
Процедура РС_ПередНачаломРаботыСистемы()
	
	ДопустимоеКолСеансов = 3;
	лкИмя = СокрЛП(ИмяПользователя());
	Отказ = РС_ОбщийМодульСервер.ПроверкаСеанса(лкИмя, ДопустимоеКолСеансов);
	
	Если Отказ Тогда
		Предупреждение(
		"У пользователя: " 
		+ лкИмя 
		+ " уже запущен(о) " 
		+ ДопустимоеКолСеансов 
		+ " сеанс(ов) 1С!",30); 
		ПрекратитьРаботуСистемы(Ложь);
	КонецЕсли;

КонецПроцедуры
